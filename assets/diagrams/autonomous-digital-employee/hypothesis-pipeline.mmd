flowchart TB
  subgraph design["1 · ДИЗАЙН"]
    direction LR
    idea["ИДЕЯ<br/>источник сигнала + причина эджа"]:::idea
    survivability{"Выживет при<br/>латентности 30–60с<br/>и ставке $5–15?"}:::gate
    desk["DESK-CHECK<br/>исполнимые цены · train/test"]:::stage
    idea --> survivability
    survivability -->|да| desk
  end

  subgraph proof["2 · ДОКАЗАТЕЛЬСТВО"]
    direction LR
    prereg["ПРЕ-РЕГИСТРАЦИЯ<br/>kill / promote до новых данных"]:::rule
    paper["FORWARD PAPER<br/>реальный поток · ноль денег"]:::paper
    evidence{"Гейт выполнен?<br/>обычно n ≥ 50<br/>и положительный ROI"}:::gate
    prereg --> paper --> evidence
  end

  subgraph capital["3 · РЕАЛЬНЫЕ ДЕНЬГИ"]
    direction LR
    micro["LIVE MICRO<br/>минимальный риск"]:::live
    scale["МАСШТАБИРОВАНИЕ<br/>капитал решает Павел"]:::owner
    micro --> scale
  end

  grave[("КЛАДБИЩЕ<br/>причина смерти + запрет реанимации")]:::grave
  wait["ДАННЫХ МАЛО<br/>продолжить paper до срока"]:::wait

  survivability -->|нет| grave
  desk -->|прошёл| prereg
  desk -->|опровергнут| grave
  evidence -->|promote| micro
  evidence -->|kill| grave
  evidence -->|рано| wait --> paper

