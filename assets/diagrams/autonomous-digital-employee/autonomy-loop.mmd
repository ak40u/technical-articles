flowchart LR
  subgraph sensing["1 · ПОЧУВСТВОВАТЬ"]
    direction TB
    schedule["Смена стартует по расписанию<br/>без сообщения человека"]:::start
    inputs["Собрать факты<br/>prod-леджер · P&L · discovery · ошибки"]:::process
    pulse["quant-desk-pulse.py<br/>robust z / MAD + сверка прогнозов"]:::code
    schedule --> inputs --> pulse
  end

  subgraph judgment["2 · ВЫНЕСТИ ВЕРДИКТ"]
    direction TB
    top3["Выбрать топ-3 странности дня"]:::process
    retrieve["Найти похожие эпизоды<br/>journal + долговременная память"]:::memory
    verdict{"Вердикт"}:::decision
    explained["ОБЪЯСНЕНО<br/>причина проверена"]:::ok
    baseline["ОБНОВИТЬ БАЗЛАЙН<br/>зафиксировать новую норму"]:::warn
    investigate["РАССЛЕДОВАТЬ<br/>починить · откатить · эскалировать"]:::alert
    top3 --> retrieve --> verdict
    verdict --> explained
    verdict --> baseline
    verdict --> investigate
  end

  subgraph learning["3 · ПОДЕЙСТВОВАТЬ И НАУЧИТЬСЯ"]
    direction TB
    action["Исполнить разрешённое действие<br/>и проверить результат"]:::process
    write["Записать журнал, решение и правило<br/>+ predictions на завтра"]:::memory
    report["Отправить короткий отчёт в Telegram"]:::channel
    next["Следующая смена получает<br/>факты, исходы и накопленный опыт"]:::start
    action --> write --> report --> next
  end

  pulse --> top3
  explained --> action
  baseline --> action
  investigate --> action

